{
  "name": "tenggouwa-site",
  "version": "0.0.1",
  "private": true,
  "description": "Tenggouwa personal monorepo: GitHub Pages frontends + FastAPI backend.",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev:web": "pnpm --filter @tenggouwa/web dev",
    "dev:admin": "pnpm --filter @tenggouwa/admin dev",
    "dev:server": "bash scripts/run-server-dev.sh",
    "build": "pnpm -r --filter \"./apps/**\" build",
    "build:web": "pnpm --filter @tenggouwa/web build",
    "build:admin": "pnpm --filter @tenggouwa/admin build",
    "build:pages": "bash scripts/build-pages.sh",
    "deploy:server": "bash scripts/deploy-server.sh",
    "lint": "pnpm -r --parallel lint"
  },
  "devDependencies": {
    "typescript": "5.6.3"
  }
}
