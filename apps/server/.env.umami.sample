# Umami 配置。复制为 .env.umami 后填好。
# 启动：docker compose -f docker-compose.umami.yml --env-file .env.umami up -d

# Umami 内部 postgres 的密码（不要跟主 stack 的密码混用）
POSTGRES_PASSWORD=change-me

# Umami session cookie 签名密钥，至少 32 位随机字符
# 生成：openssl rand -base64 48
APP_SECRET=change-me-to-random-string-at-least-32-chars
