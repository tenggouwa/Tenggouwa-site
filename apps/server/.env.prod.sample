# 生产环境变量模板。部署时复制到服务器：
#   cp .env.prod.sample .env
# 然后填入实际值。注意 .env 不会被 rsync 覆盖（deploy-server.sh 已 exclude）。

# Postgres 密码（自己定，强密码）
POSTGRES_DEFAULT_PASSWORD=改成一个强随机串

# JWT 签名密钥（长随机串，泄露 = 任何人都能伪造登录态）
# 生成：python3 -c "import secrets;print(secrets.token_urlsafe(48))"
AUTH_JWT_SECRET=改成长随机串

# 后台账号的 bcrypt 密码哈希
# 生成（本地跑一次即可，把输出贴这里）：
#   python3 -c "import bcrypt;print(bcrypt.hashpw(b'你的明文密码', bcrypt.gensalt()).decode())"
ADMIN_TENGGOUWA_PASSWORD_HASH=$2b$12$改成实际哈希

# Cloudflare Tunnel 的 connector token
# Cloudflare dashboard → Zero Trust → Networks → Tunnels → 新建 → Docker → 复制 token
CLOUDFLARE_TUNNEL_TOKEN=改成实际 token

# 树莓派 pi-agent 上报鉴权 token（与 Pi 上 install.sh 填的同一个）
# 生成：python3 -c "import secrets;print(secrets.token_urlsafe(32))"
PI_AGENT_TOKEN=改成长随机串

