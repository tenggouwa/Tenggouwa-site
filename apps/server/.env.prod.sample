# 生产环境变量模板。部署时复制到服务器：
#   cp .env.prod.sample .env
# 然后填入实际值。注意 .env 不会被 rsync 覆盖（deploy-server.sh 已 exclude）。

# Postgres 密码（自己定，强密码）
POSTGRES_DEFAULT_PASSWORD=改成一个强随机串

# JWT 签名密钥（长随机串，泄露 = 任何人都能伪造登录态）
# 生成：python3 -c "import secrets;print(secrets.token_urlsafe(48))"
AUTH_JWT_SECRET=改成长随机串

# 后台账号的 bcrypt 密码哈希
# 生成（本地跑一次即可，把输出贴这里）：
#   python3 -c "import bcrypt;print(bcrypt.hashpw(b'你的明文密码', bcrypt.gensalt()).decode())"
ADMIN_TENGGOUWA_PASSWORD_HASH=$2b$12$改成实际哈希

# Cloudflare Tunnel 的 connector token
# Cloudflare dashboard → Zero Trust → Networks → Tunnels → 新建 → Docker → 复制 token
CLOUDFLARE_TUNNEL_TOKEN=改成实际 token

# 树莓派 pi-agent 上报鉴权 token（与 Pi 上 install.sh 填的同一个）
# 生成：python3 -c "import secrets;print(secrets.token_urlsafe(32))"
PI_AGENT_TOKEN=改成长随机串

# KB 知识库问答的生成模型（OpenAI 兼容，默认直连 DeepSeek 官方）
# 换供应商只改这三个
KB_LLM_BASE_URL=https://api.deepseek.com
KB_LLM_MODEL=deepseek-chat
KB_LLM_API_KEY=改成 DeepSeek 官方 sk-... key

# KB 语义检索的嵌入模型（OpenAI 兼容，默认 OpenRouter baai/bge-m3 = 1024 维）
# 不配 KB_EMBED_API_KEY 时自动降级为纯 pg_trgm 检索（无语义搜索）
KB_EMBED_BASE_URL=https://openrouter.ai/api/v1
KB_EMBED_MODEL=baai/bge-m3
KB_EMBED_API_KEY=改成 OpenRouter 的 sk-or-... key

# 可选：深度思考模式使用的模型；不设时默认 deepseek-reasoner
# KB_LLM_REASONER_MODEL=deepseek-reasoner

# Agent 私有 token 有效期（分钟，默认 240）
# AGENT_TOKEN_TTL_MIN=240

# 匿名 Agent 会话保留天数（默认 7）；私有 owner 会话不受影响
# AGENT_ANONYMOUS_RETENTION_DAYS=7

# 启用 Pi bwrap 沙箱后的文件/shell/git 工具。Pi 侧也必须配置 PI_AGENT_EXEC=1。
# AGENT_PI_SANDBOX=1

# MCP server 白名单，JSON 数组；留空即完全禁用。未设 auto=true 的 server 工具逐项审批。
# stdio 示例：
# MCP_SERVERS=[{"name":"time","transport":"stdio","command":"mcp-server-time","args":[],"auto":true}]
# MCP_CONNECT_TIMEOUT=20
# MCP_LIST_TIMEOUT=10
# MCP_CALL_TIMEOUT=30

# 可选：Search Console 定时拉取。JSON 内容或文件二选一。
# GSC_SERVICE_ACCOUNT_JSON={...}
# GSC_SERVICE_ACCOUNT_FILE=/run/secrets/gsc-service-account.json
# GSC_SITE_URL=sc-domain:tenggouwa.com

# 可选：搜索引擎索引状态/提交能力
# BAIDU_TOKEN=
# BING_WEBMASTER_API_KEY=
